{
  "name": "microlearning-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "supabase start",
    "functions:serve": "supabase functions serve --env-file .env.local",
    "functions:deploy": "supabase functions deploy",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "test": "deno test --allow-net --allow-env src/**/*.test.ts",
    "test:pipeline": "deno run --allow-net --allow-env scripts/test-pipeline.ts",
    "lint": "deno lint src/"
  },
  "devDependencies": {
    "supabase": "^1.200.0"
  }
}
